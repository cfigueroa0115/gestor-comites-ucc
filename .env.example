# =============================================================================
# Portal Gestión de Comités - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local with real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string for Neon PostgreSQL database
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/gestor_comites?sslmode=require"

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
# Secret key for encrypting iron-session cookies (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-of-at-least-32-characters"

# -----------------------------------------------------------------------------
# Initial Admin User (used during database seed)
# -----------------------------------------------------------------------------
# Username for the initial administrator account
ADMIN_USER="admin"

# Password for the initial administrator account (min 8 chars, 1 uppercase, 1 lowercase, 1 number)
ADMIN_PASSWORD="Admin123!"

# Email for the initial administrator account
ADMIN_EMAIL="admin@example.com"

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# AI provider to use: "openai" | "anthropic" | "" (empty = fallback mode, no AI)
AI_PROVIDER=""

# API key for the configured AI provider
AI_API_KEY="sk-your-api-key-here"

# AI model to use (e.g., "gpt-4o", "claude-sonnet-4-20250514")
AI_MODEL="gpt-4o"

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size in MB for uploaded attachments
MAX_FILE_SIZE_MB="10"

# -----------------------------------------------------------------------------
# File Storage Configuration
# -----------------------------------------------------------------------------
# Storage provider: "local" (development) | "vercel-blob" (production)
STORAGE_PROVIDER="local"

# Vercel Blob read/write token (required only when STORAGE_PROVIDER=vercel-blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token-here"
